{
  "name": "bibliophile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cross-platform Electron rewrite of BibDesk (placeholder name; user renames later).",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:pkgs": "pnpm -r test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm --filter @bibdesk/app dev",
    "build:app": "pnpm --filter @bibdesk/app build:app",
    "rebuild:electron": "node scripts/rebuild-native.mjs electron",
    "pack:dir": "pnpm rebuild:electron && pnpm build:app && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir",
    "dist": "pnpm rebuild:electron && pnpm build:app && electron-builder",
    "dist:mac": "pnpm rebuild:electron && pnpm build:app && electron-builder --mac"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.2",
    "electron-builder": "^24.13.3",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}

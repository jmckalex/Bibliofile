auto-install-peers=true
strict-peer-dependencies=false
# Don't auto-run `pnpm install` before `pnpm run` scripts. Avoids ignored-build-script
# exit codes blocking `pnpm -r test` / `pnpm -r build`. esbuild's native binary is
# present via its platform package, so its skipped postinstall is harmless.
verify-deps-before-run=false

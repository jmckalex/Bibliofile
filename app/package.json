{
  "name": "@bibdesk/app",
  "version": "0.11.0",
  "private": true,
  "type": "module",
  "description": "Bibliofile — cross-platform BibTeX bibliography manager (Electron shell: main + preload + renderer).",
  "author": "J. McKenzie Alexander <jmckalex@gmail.com>",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build:app": "electron-vite build",
    "start": "electron-vite preview",
    "build": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run --passWithNoTests",
    "rebuild:electron": "node ../scripts/rebuild-native.mjs electron",
    "rebuild:node": "node ../scripts/rebuild-native.mjs node"
  },
  "dependencies": {
    "@bibdesk/bibtex": "workspace:*",
    "@bibdesk/formats": "workspace:*",
    "@bibdesk/groups": "workspace:*",
    "@bibdesk/model": "workspace:*",
    "@bibdesk/names": "workspace:*",
    "@bibdesk/shared": "workspace:*",
    "@bibdesk/tex": "workspace:*",
    "@citation-js/core": "^0.7.21",
    "@citation-js/plugin-csl": "^0.7.22",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.15",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@lezer/highlight": "^1.2.3",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.10.9",
    "autolinker": "^4.1.5",
    "better-sqlite3": "^11.10.0",
    "bindings": "^1.5.0",
    "fast-xml-parser": "^4.5.6",
    "file-uri-to-path": "^1.0.0",
    "handlebars": "^4.7.9",
    "highlight.js": "^11.11.1",
    "iconv-lite": "^0.7.2",
    "lz-string": "^1.5.0",
    "marked": "^14.1.4",
    "mathjax": "^3.2.2",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.17.5",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.11"
  }
}

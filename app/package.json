{
  "name": "@bibdesk/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Electron shell: main process, preload, and React renderer (read-only viewer this session).",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",

@article{basel1748,
	Abstract = {Euler evaluates the **Basel problem**, showing that $\sum_{n=1}^{\infty} \frac{1}{n^2} = \frac{\pi^2}{6}$. The argument proceeds by:

- expanding $\frac{\sin x}{x}$ as an *infinite product*,
- comparing coefficients of $x^2$,

a method later made rigorous by Weierstrass. See also [the DOI](https://doi.org/10.1000/euler.1748).},
	Annote = {Foundational zeta-function result. The operator-theoretic viewpoint is developed in [[dirac1930]] (and compare the missing ref [[riemann1859]]).

